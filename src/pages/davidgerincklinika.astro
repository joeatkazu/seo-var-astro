---
import BaseLayout from "@/layouts/BaseLayout.astro";

const videoTitle = "David Gerinc Klinika - Weboldal Audit";
const videoDescription = "Reszletes elemzes a weboldal teljesitmenyerol es optimalizalasi lehetosegeirol.";
---

<BaseLayout 
  title="Audit Video - David Gerinc Klinika | KeresoPartner"
  description="Audit video a David Gerinc Klinika weboldalanak elemzeserol."
  noindex={true}
>
  <div class="min-h-screen bg-gray-50 py-12 px-4">
    <div class="max-w-5xl mx-auto">
      <div class="bg-white rounded-lg shadow-lg p-6 md:p-8">
        <h1 class="text-2xl md:text-3xl font-bold text-gray-900 mb-2">
          {videoTitle}
        </h1>
        <p class="text-gray-600 mb-6">
          {videoDescription}
        </p>
        
        <div class="relative aspect-video bg-gray-900 rounded-lg overflow-hidden">
          <video
            controls
            class="w-full h-full"
            preload="metadata"
          >
            <source src="/davidgerincklinika.mp4" type="video/mp4" />
            A bongeszo nem tamogatja a video lejatszast.
          </video>
        </div>
        
        <div class="mt-6 flex justify-between items-center">
          <p class="text-sm text-gray-500">
            Video meret: ~10 MB | Formátum: MP4
          </p>
          <a 
            href="/davidgerincklinika.mp4" 
            download 
            class="text-blue-600 hover:text-blue-800 font-medium"
          >
            Letoltes
          </a>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
